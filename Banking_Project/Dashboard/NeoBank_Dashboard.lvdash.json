{
  "datasets": [
    {
      "name": "ca22f70a",
      "displayName": "Total Customers",
      "queryLines": [
        "SELECT COUNT(DISTINCT customer_id) AS total_customers FROM banking.gold.customer_360"
      ]
    },
    {
      "name": "b0779541",
      "displayName": "Total Deposits",
      "queryLines": [
        "SELECT SUM(total_balance) AS total_deposits FROM banking.gold.customer_360"
      ]
    },
    {
      "name": "810b9c0b",
      "displayName": "Total Transactions",
      "queryLines": [
        "SELECT SUM(total_transactions) AS total_transactions FROM banking.gold.customer_360"
      ]
    },
    {
      "name": "7f02a47b",
      "displayName": "High Risk Cusomers",
      "queryLines": [
        "SELECT COUNT(*) AS high_risk_customers FROM banking.gold.customer_360 WHERE risk_grade = 'HIGH'"
      ]
    },
    {
      "name": "71caaa4e",
      "displayName": "Customer Segment Distribution",
      "queryLines": [
        "SELECT customer_segment, COUNT(*) AS customers FROM banking.gold.customer_360 GROUP BY customer_segment"
      ]
    },
    {
      "name": "fe05fad1",
      "displayName": "Credit Risk Distribution",
      "queryLines": [
        "SELECT risk_grade, COUNT(*) AS customers FROM banking.gold.customer_360 GROUP BY risk_grade"
      ]
    },
    {
      "name": "fb0cea9f",
      "displayName": "Top Customeers",
      "queryLines": [
        "SELECT customer_name, branch_name, total_balance FROM banking.gold.customer_360 ORDER BY total_balance DESC LIMIT 10"
      ]
    },
    {
      "name": "702c4cc6",
      "displayName": "Branch Deposits",
      "queryLines": [
        "SELECT branch_name, total_deposits FROM banking.gold.branch_performance ORDER BY total_deposits DESC"
      ]
    },
    {
      "name": "db119721",
      "displayName": "Branch Customers",
      "queryLines": [
        "SELECT branch_name, total_customers FROM banking.gold.branch_performance ORDER BY total_customers DESC"
      ]
    },
    {
      "name": "6143a63b",
      "displayName": "Branch Transactions",
      "queryLines": [
        "SELECT branch_name, total_transaction_amount FROM banking.gold.branch_performance ORDER BY total_transaction_amount DESC"
      ]
    },
    {
      "name": "647247cb",
      "displayName": "Gateway transactions",
      "queryLines": [
        "SELECT gateway_name, SUM(successful_transactions) AS successful_transactions, SUM(failed_transactions) AS failed_transactions FROM banking.gold.transaction_channel_summary GROUP BY gateway_name"
      ]
    },
    {
      "name": "b43f9041",
      "displayName": "Device transactions",
      "queryLines": [
        "SELECT device_type, SUM(total_transactions) AS total_transactions FROM banking.gold.transaction_channel_summary GROUP BY device_type"
      ]
    }
  ],
